{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "typeRoots": ["./node_modules/@types", "../node_modules/@types"],
    "types": ["node"]
  },
  "include": ["seed.ts"],
  "exclude": ["node_modules"]
}