{
  "name": "guhaya-sourcing",
  "private": true,
  "version": "0.1.0",
  "description": "Guhaya Sourcing monorepo (frontend, backend, database).",
  "workspaces": [
    "frontend",
    "backend",
    "database"
  ],
  "scripts": {
    "dev": "concurrently -n FRONTEND,BACKEND -c cyan,magenta \"npm:dev:frontend\" \"npm:dev:backend\"",
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:backend": "npm --workspace backend run dev",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "npm --workspace frontend run build",
    "build:backend": "npm --workspace backend run build",
    "lint": "npm --workspace frontend run lint && npm --workspace backend run lint",
    "format": "prettier -w .",
    "typecheck": "npm --workspace frontend run typecheck && npm --workspace backend run typecheck"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.1.2",
    "prettier": "^3.6.2",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "lucide-react": "^1.7.0"
  }
}
